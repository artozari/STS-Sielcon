<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Habilitar Máquina - STS</title>
    <link rel="stylesheet" href="./styles.css">
    <link rel="stylesheet" href="./css/habilitar-maquina.css">
</head>

<body>
    <header>
        <div class="menu-container">
            <div class="hamburguer" id="hamburguer">
                <span></span>
                <span></span>
                <span></span>
            </div>

            <ul class="menu-list" id="menu-list">
                <li><a href="/">Inicio</a></li>
                <li><a href="/habilitar-maquina">Habilitar Máquina</a></li>
            </ul>
        </div>
        <div class="card">
            <div class="bg">
                <div class="rellenoIzquierdo">
                    <p>
                        <span id="fechaActual" class="fechaActual"></span>
                        <script>
                            const actualizarFecha = () => {
                                const fechaActualElement = document.querySelector("#fechaActual");
                                const fecha = new Date();
                                fechaActualElement.innerText = new Intl.DateTimeFormat('default', { year: 'numeric', month: 'short', day: 'numeric' }).format(fecha);
                            }
                            setInterval(actualizarFecha, 1000);
                        </script>
                    </p>
                    <p>
                        <span id="horaActual" class="horaActual"></span>
                        <script>
                            const actualizarHora = () => {
                                const horaActualElement = document.querySelector("#horaActual");
                                const fecha = new Date();
                                horaActualElement.innerText = new Intl.DateTimeFormat('default', { hour: '2-digit', minute: '2-digit', second: '2-digit' }).format(fecha);
                            }
                            setInterval(actualizarHora, 1000);
                        </script>
                    </p>
                </div>
                <div class="logo-container">
                    <img src="./logo_sielcon_page.png" alt="" srcset="">
                    <p>Sign Table System</p>
                </div>
                <% if (tableNumber !==undefined) { %>
                    <h1 class="header-title" data-tableNumber="<%= JSON.stringify(tableNumber) %>">
                        STS MESA: <%= tableNumber %>
                    </h1>
                    <% } else { %>
                        <h1 class="header-title">
                            STS MESA
                        </h1>
                        <% } %>
            </div>
            <div class="blob"></div>
        </div>
    </header>

    <main>
        <a href="/" class="btn-back">← Volver</a>
        <div class="machine-form-container">
            <% if (tableNumber !==undefined) { %>
                <h2>MESA <%= tableNumber %>
                </h2>
                <% } else { %>
                    <h2>MESA</h2>
                    <% } %>

                        <form class="machineForm" id="machineForm">
                            <div class="form-row">
                                <button type="submit" id="generateCodeBtn" class="btn-generate">
                                    + GENERAR CODIGO
                                </button>

                                <div class="code-group">
                                    <label>COD:</label>
                                    <div class="code-inputs-horizontal">
                                        <input type="text" id="cod1" name="cod1" placeholder="2026-UID234">
                                        <input type="text" id="cod2" name="cod2" placeholder="KID-UID567">
                                    </div>
                                </div>

                                <div class="key-group">
                                    <label>Key:</label>
                                    <input type="text" id="key" name="key" placeholder="k2026234567">
                                </div>

                                <button type="submit" class="btn-save" id="saveKey">Guardar</button>
                            </div>

                            <div class="error-message" id="errorMessage">

                            </div>

                            <div class="loading" id="loading">
                                <div class="spinner"></div>
                                <p>Procesando solicitud...</p>
                            </div>
                        </form>
        </div>
    </main>

    <footer>
        <p>&copy; 2025 Sielcon</p>
    </footer>

    <script src="./js/habilitar-maquina.js" defer></script>
</body>

</html>